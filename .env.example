# ============================================================================
# PostgreSQL Database Configuration
# ============================================================================
# Konfiguration für den PostgreSQL-Datenbankserver.
# Diese Variablen werden beim Start des Containers geladen.

# Datenbankname
# Wird beim ersten Start automatisch erstellt
POSTGRES_DB=lld_panel

# Root-Benutzer
# Dieser Benutzer hat administrative Rechte
POSTGRES_USER=postgres

# Root-Passwort
# SICHERHEIT: Mindesenlänge 16 Zeichen, nicht vorhersehbar
# Beispiel (nicht verwenden!): postgres_secure_password_12345
POSTGRES_PASSWORD=change_me_in_production_123456
